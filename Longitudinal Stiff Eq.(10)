%% Analytical Longitudinal Stiffness vs In-Plane Curvature Angle α (Figure 5b)
%
% Eq. (10):  k_eff(α) = k_ax * cos²(α) + k_b * sin²(α)
%          = k_b + (k_ax - k_b) * cos²(α)
%
% PURPOSE: Show that increasing in-plane curvature angle α reduces
%          effective longitudinal stiffness — load path shifts from
%          stiff axial mode to compliant bending mode.
%
% Physical interpretation:
%   α → 0°:  k_eff ≈ k_ax  (axial-dominant, stiff)
%   α → 90°: k_eff → k_b   (bending-dominant, compliant)
%   Monotonic softening: dk_eff/dα < 0  (Eq. 13)
%
% Spoke geometry (from paper Section 2):
%   L = 75 mm, t = 2 mm, D = 60 mm → I = 40 mm^4
%   Fixed-fixed beam: C_b = 12
%
% Reference α values (from Eq. 3, r = 1,3,4,6 mm):
%   α_max = 4.8°, 14.1°, 18.5°, 26.7°
% ────────────────────────────────────────────────────────────────────────

clear; clc; close all;

%% ── Spoke geometry ───────────────────────────────────────────────────────
L  = 75.0;            % mm   — spoke height
t  = 2.0;             % mm   — thickness
D  = 60.0;            % mm   — out-of-plane depth
A  = t * D;           % mm^2 — cross-sectional area = 120 mm^2
I  = D * t^3 / 12;    % mm^4 — second moment of area = 40 mm^4
E  = 200.0;           % MPa  — representative PU modulus

fprintf('Spoke geometry:\n');
fprintf('  A = %.1f mm^2,  I = %.1f mm^4,  L = %.0f mm\n', A, I, L);

%% ── Stiffness components (Eq. 5) ─────────────────────────────────────────
C_b = 12;                          % fixed-fixed boundary condition
k_ax = E * A / L;                  % N/mm — axial stiffness
k_b  = C_b * E * I / L^3;         % N/mm — bending stiffness

fprintf('\nStiffness components:\n');
fprintf('  k_ax = %.4f N/mm  (axial)\n',   k_ax);
fprintf('  k_b  = %.6f N/mm  (bending)\n', k_b);
fprintf('  k_ax / k_b = %.1f  (axial >> bending for slender spoke)\n', k_ax/k_b);

%% ── Normalized stiffness curve ───────────────────────────────────────────
alpha_deg = linspace(0, 90, 500);
alpha_rad = deg2rad(alpha_deg);

% Eq. (10): k_eff normalized by k_ax
k_eff_norm = (k_ax .* cos(alpha_rad).^2 + k_b .* sin(alpha_rad).^2) / k_ax;

%% ── Reference α values from paper ───────────────────────────────────────
% α = arctan(2π*r/L),  r = 1, 3, 4, 6 mm  (Eq. 3)
r_vals     = [1, 3, 4, 6];
alpha_ref  = atand(2*pi*r_vals / L);          % degrees: [4.8, 14.1, 18.5, 26.7]
k_ref_norm = (k_ax .* cosd(alpha_ref).^2 + k_b .* sind(alpha_ref).^2) / k_ax;

fprintf('\nReference points (r → α → k_eff/k_ax):\n');
for i = 1:length(r_vals)
    fprintf('  r = %d mm → α = %.1f° → k_eff/k_ax = %.4f\n', ...
            r_vals(i), alpha_ref(i), k_ref_norm(i));
end

% Reduction from α=4.8° to α=26.7° (matches paper: ~17.7%)
reduction = (k_ref_norm(1) - k_ref_norm(end)) / k_ref_norm(1) * 100;
fprintf('\nReduction from α=%.1f° to α=%.1f°: %.1f%%  (paper reports 17.7%%)\n', ...
        alpha_ref(1), alpha_ref(end), reduction);

%% ── Plot ─────────────────────────────────────────────────────────────────
figure('Units','centimeters','Position',[5 5 14 11]);
hold on;

% Main curve
plot(alpha_deg, k_eff_norm, 'b-', 'LineWidth', 2.5, 'DisplayName', ...
     'k_{eff}/k_{ax} — Eq. (10)');

% Reference points (r = 1, 3, 4, 6)
ref_colors = [0.122 0.306 0.475;
              0.161 0.502 0.725;
              0.153 0.682 0.376;
              0.906 0.298 0.235];

for i = 1:length(alpha_ref)
    plot(alpha_ref(i), k_ref_norm(i), 'o', ...
         'Color',           ref_colors(i,:), ...
         'MarkerFaceColor', ref_colors(i,:), ...
         'MarkerSize',      9, ...
         'DisplayName',     ['\alpha = ' sprintf('%.1f', alpha_ref(i)) '\circ  (r=' num2str(r_vals(i)) ' mm)']);
end

%% ── 17.7% drop annotation ────────────────────────────────────────────────
% Vertical dashed lines at α = 4.8° and α = 26.7°
plot([alpha_ref(1) alpha_ref(1)], [0 k_ref_norm(1)], '--', ...
     'Color',[0.6 0.6 0.6], 'LineWidth',0.9, 'HandleVisibility','off');
plot([alpha_ref(end) alpha_ref(end)], [0 k_ref_norm(end)], '--', ...
     'Color',[0.6 0.6 0.6], 'LineWidth',0.9, 'HandleVisibility','off');

% Arrow showing drop
mid_alpha = mean([alpha_ref(1), alpha_ref(end)]);
plot([alpha_ref(1) alpha_ref(end)], ...
     [k_ref_norm(end) k_ref_norm(end)], '-', ...
     'Color',[0.5 0.5 0.5], 'LineWidth',1.2, 'HandleVisibility','off');
text(mid_alpha, k_ref_norm(end) - 0.04, ...
     sprintf('%.1f%% drop', reduction), ...
     'HorizontalAlignment','center', 'FontSize', 9.5, ...
     'Color', [0.35 0.35 0.35]);

%% ── k_b asymptote ────────────────────────────────────────────────────────
yline(k_b/k_ax, ':', 'Color',[0.7 0.3 0.1], 'LineWidth',1.5, ...
      'HandleVisibility','off');
text(88, k_b/k_ax + 0.02, 'k_b / k_{ax}', ...
     'HorizontalAlignment','right', 'FontSize',9, 'Color',[0.7 0.3 0.1]);

%% ── Regime labels ────────────────────────────────────────────────────────
text(5,  0.92, {'Axial-dominant', '(stiff)'}, ...
     'FontSize',8.5, 'Color',[0.2 0.4 0.7], 'HorizontalAlignment','left');
text(75, 0.30, {'Bending-dominant', '(compliant)'}, ...
     'FontSize',8.5, 'Color',[0.7 0.2 0.2], 'HorizontalAlignment','center');

%% ── Formatting ───────────────────────────────────────────────────────────
xlim([0, 90]);
ylim([0, 1.05]);
xlabel('In-plane curvature angle  \alpha  (deg)', 'FontSize', 12);
ylabel('Normalized stiffness  k_{eff} / k_{ax}',  'FontSize', 12);
title('Curvature-dependent longitudinal stiffness — Eq. (10)', ...
      'FontSize', 11, 'FontWeight', 'normal');
legend('Location','northeast', 'FontSize', 9.5, 'Box','on');
grid on; box on;
set(gca, 'FontSize',11, 'LineWidth',1.0, 'GridAlpha',0.3);

%% ── Parameter box ────────────────────────────────────────────────────────
param_str = {sprintf('k_{ax} = EA/L = %.1f N/mm', k_ax), ...
             sprintf('k_b = 12EI/L^3 = %.4f N/mm', k_b), ...
             sprintf('k_{ax}/k_b = %.0f', k_ax/k_b)};
text(0.03, 0.38, param_str, ...
     'Units','normalized', 'FontSize',8.5, ...
     'BackgroundColor',[0.95 0.97 0.99], ...
     'EdgeColor',     [0.70 0.75 0.82], 'Margin', 4);

%% ── Qualitative note ─────────────────────────────────────────────────────
text(0.01, 0.01, ...
     '* Normalized by k_{ax}; E = 200 MPa, C_b = 12 (fixed-fixed)', ...
     'Units','normalized', 'FontSize',7.5, 'Color',[0.45 0.45 0.45], ...
     'VerticalAlignment','bottom');

hold off;

