%% =========================================================
%  LOCAL HELPER – RdYlGn colormap (256 colors)
%  Red → Yellow → Green
%% =========================================================
function cmap = rdylgn_cmap(n)
    anchors = [0.647  0.000  0.149;   % dark red
               0.957  0.427  0.263;   % orange-red
               0.996  0.878  0.545;   % light yellow
               1.000  1.000  0.749;   % pale yellow
               0.851  0.937  0.545;   % light green
               0.400  0.741  0.388;   % medium green
               0.000  0.408  0.216];  % dark green
    x  = linspace(0, 1, size(anchors,1));
    xi = linspace(0, 1, n);
    cmap = interp1(x, anchors, xi, 'pchip');
    cmap = max(0, min(1, cmap));
end
